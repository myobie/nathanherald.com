#!/usr/bin/env bash

set -e

# Check arguments
if [ $# -eq 0 ]; then
    echo "Usage: $0 <markdown-file>"
    echo "Example: $0 src/posts/my-post/index.md"
    echo ""
    echo "This script will:"
    echo "1. Build the site (for src/ posts) or convert markdown to HTML (for public/ posts)"
    echo "2. Add the post to the RSS feed"
    echo "3. For public/ posts: add to homepage and archive (src/ posts use custom elements)"
    exit 1
fi

# Get the absolute path to the repo root
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Input file
INPUT_FILE="$1"

# Check if input file exists
if [ ! -f "$INPUT_FILE" ]; then
    echo "Error: File '$INPUT_FILE' not found"
    exit 1
fi

echo "🚀 Publishing post: $INPUT_FILE"
echo ""

# Detect src/ vs public/ path
USE_SRC=false
case "$INPUT_FILE" in
    src/*|*/src/*) USE_SRC=true ;;
esac

if $USE_SRC; then
    # src/ path: build handles everything except RSS
    echo "🔨 Step 1: Building src/ to public/..."
    cd "$REPO_ROOT" && deno task build
    echo ""

    echo "📡 Step 2: Adding to RSS feed..."
    "$REPO_ROOT/bin/add-rss-item" "$INPUT_FILE"
    echo ""
else
    # public/ path: md2html + RSS + homepage + archive
    echo "📄 Step 1: Converting markdown to HTML..."
    "$REPO_ROOT/bin/md2html" "$INPUT_FILE"
    echo ""

    echo "📡 Step 2: Adding to RSS feed..."
    "$REPO_ROOT/bin/add-rss-item" "$INPUT_FILE"
    echo ""

    echo "🏠 Step 3: Adding to homepage..."
    "$REPO_ROOT/bin/add-to-homepage" "$INPUT_FILE"
    echo ""

    echo "📚 Step 4: Adding to posts archive..."
    "$REPO_ROOT/bin/add-to-archive" "$INPUT_FILE"
    echo ""
fi

echo "✅ Post published successfully!"
echo ""
echo "Next steps:"
echo "- Review the changes with 'git diff'"
echo "- Test the website locally"
echo "- Commit and push when ready"
